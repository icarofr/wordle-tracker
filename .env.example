# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wordle-tracker

# ── Go API ─────────────────────────────────────────────────────────────────────
# Database connection string — composed from the vars above by compose.yaml
# DB_DSN is set automatically; only override if you need a custom format.
# DB_DSN=postgres:changeme@api:5432/wordle-tracker?sslmode=disable
HTTP_PORT=4000
DB_AUTOMIGRATE=true
CORS_ORIGINS=http://localhost:8080

# ── Client ─────────────────────────────────────────────────────────────────────
# URL of the Go API as seen from the browser.
# For the default compose stack this is the Caddy proxy: http://localhost:8080/api
VITE_API_URL=http://localhost:8080/api
