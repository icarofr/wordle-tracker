{
  "name": "wordle-client",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 3000",
    "start": "vite --port 3000",
    "build": "vite build && tsc -p tsconfig.build.json",
    "serve": "vite preview",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/router-plugin": "^1.109.2",
    "@tanstack/solid-router": "^1.110.0",
    "@tanstack/solid-router-devtools": "^1.109.2",
    "@types/leaflet": "^1.9.18",
    "leaflet": "^1.9.4",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.4",
    "tailwindcss": "^4.2.2",
    "wordcloud": "^1.2.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.5.2",
    "@types/wordcloud": "^1.2.2",
    "eslint": "^10.2.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.0.2",
    "lightningcss": "^1.30.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.2",
    "openapi-typescript": "^7.13.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.11",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-solid": "^2.11.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp",
      "simple-git-hooks"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "if [ \"$1\" = 'public' ] && [ \"${PUSH_PUBLIC_ALLOWED:-}\" != '1' ]; then echo 'Blocked: use make push/public'; exit 1; fi"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": "eslint --fix",
    "*.{json,yaml,md}": "eslint --fix"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
